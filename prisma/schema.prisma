datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String            @id @default(uuid())
  name            String
  branch          String
  currentSemester Int
  textbooks       Textbook[]        @relation("UserTextbooks")
  resources       DigitalResource[] @relation("UserResources")
  requests        HandoverRequest[] @relation("UserRequests")
}

model Textbook {
  id        String            @id @default(uuid())
  title     String
  semester  Int
  condition String
  status    String            @default("Available") // Available, Pending, Handed_Over
  ownerId   String
  owner     User              @relation("UserTextbooks", fields: [ownerId], references: [id], onDelete: Cascade)
  requests  HandoverRequest[] @relation("TextbookRequests")
}

model DigitalResource {
  id         String   @id @default(uuid())
  title      String
  semester   Int
  category   String   // Notes, QuestionPaper, LabManual
  url        String
  uploaderId String
  uploader   User     @relation("UserResources", fields: [uploaderId], references: [id], onDelete: Cascade)
}

model HandoverRequest {
  id          String   @id @default(uuid())
  textbookId  String
  textbook    Textbook @relation("TextbookRequests", fields: [textbookId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User     @relation("UserRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  status      String   @default("Pending") // Pending, Accepted, Completed
}
